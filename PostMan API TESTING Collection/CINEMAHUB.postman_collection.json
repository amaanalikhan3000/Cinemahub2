		{
			"name": "Movies Controller APIs Success Cases",
			"item": [
				{
					"name": "Get Movies",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let response = pm.response.json();\r",
									"\r",
									"if (response.shows && response.shows.length > 0) {\r",
									"    let showId = response.shows[0].showId;\r",
									"    pm.environment.set(\"showId\", showId);\r",
									"} else {\r",
									"    console.log(\" No shows found in response\");\r",
									"}\r",
									"\r",
									"pm.test(\"Status code is 200 - Movie with shows fetched successfully\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Response has correct structure for movie and shows\", function () {\r",
									"    const jsonData = pm.response.json();\r",
									"\r",
									"    pm.expect(jsonData).to.have.property(\"movieName\").that.is.a(\"string\");\r",
									"    pm.expect(jsonData).to.have.property(\"genre\").that.is.a(\"string\");\r",
									"    pm.expect(jsonData).to.have.property(\"duration\").that.is.a(\"string\");\r",
									"    pm.expect(jsonData).to.have.property(\"shows\").that.is.an(\"array\").that.is.not.empty;\r",
									"});\r",
									"\r",
									"pm.test(\"Each show has valid show details\", function () {\r",
									"    const jsonData = pm.response.json();\r",
									"    jsonData.shows.forEach(show => {\r",
									"        pm.expect(show).to.have.property(\"showId\").that.is.a(\"number\");\r",
									"        pm.expect(show).to.have.property(\"theaterName\").that.is.a(\"string\");\r",
									"        pm.expect(show).to.have.property(\"showDate\").that.is.a(\"string\");\r",
									"        pm.expect(show).to.have.property(\"showTime\").that.is.a(\"string\");\r",
									"    });\r",
									"});\r",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/v1/movies/{{movieName }}/shows",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"v1",
								"movies",
								"{{movieName }}",
								"shows"
							]
						}
					},
					"response": []
				},
				{
					"name": "Top 5 titles",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 - Top 5 titles fetched\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Response should be an array of movies\", function () {\r",
									"    const jsonData = pm.response.json();\r",
									"    pm.expect(jsonData).to.be.an(\"array\").that.is.not.empty;\r",
									"});\r",
									"\r",
									"pm.test(\"Each movie should have movieName and movieId\", function () {\r",
									"    const jsonData = pm.response.json();\r",
									"    jsonData.forEach(movie => {\r",
									"        pm.expect(movie).to.have.property(\"movieName\");\r",
									"        pm.expect(movie.movieName).to.be.a(\"string\").that.is.not.empty;\r",
									"\r",
									"        pm.expect(movie).to.have.property(\"movieId\");\r",
									"        pm.expect(movie.movieId).to.be.a(\"number\");\r",
									"    });\r",
									"});\r",
									"\r",
									"pm.test(\"Should return at most 5 movies\", function () {\r",
									"    const jsonData = pm.response.json();\r",
									"    pm.expect(jsonData.length).to.be.at.most(5);\r",
									"});\r",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/nowShowingMovie/top5titles",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"nowShowingMovie",
								"top5titles"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Seat Controller Success API Cases",
			"item": [
				{
					"name": "Book Seats",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201 - Seats booked successfully\", function () {\r",
									"    pm.response.to.have.status(201);\r",
									"});\r",
									"\r",
									"pm.test(\"Response has booking details and structure\", function () {\r",
									"    const jsonData = pm.response.json();\r",
									"\r",
									"    pm.expect(jsonData).to.have.property(\"schedule\");\r",
									"    pm.expect(jsonData).to.have.property(\"transactionDetail\");\r",
									"    pm.expect(jsonData).to.have.property(\"cancellationPolicy\");\r",
									"\r",
									"    // Schedule validations\r",
									"    const schedule = jsonData.schedule;\r",
									"    pm.expect(schedule).to.have.property(\"movieTitle\").that.is.a(\"string\");\r",
									"    pm.expect(schedule).to.have.property(\"date\").that.is.a(\"string\");\r",
									"    pm.expect(schedule).to.have.property(\"tickets\").that.is.a(\"string\");\r",
									"    pm.expect(schedule).to.have.property(\"hours\").that.is.a(\"string\");\r",
									"\r",
									"    // Transaction detail validations\r",
									"    const transaction = jsonData.transactionDetail;\r",
									"    pm.expect(transaction).to.have.property(\"regularSeatPrice\").that.is.a(\"number\");\r",
									"    pm.expect(transaction).to.have.property(\"numberOfTickets\").that.is.a(\"number\");\r",
									"    pm.expect(transaction).to.have.property(\"serviceChargePerTicket\").that.is.a(\"number\");\r",
									"    pm.expect(transaction).to.have.property(\"totalPayment\").that.is.a(\"number\");\r",
									"\r",
									"    // Cancellation policy check\r",
									"    pm.expect(jsonData.cancellationPolicy).to.include(\"No cancellation\");\r",
									"});\r",
									" "
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n  \"showId\": {{showId}},\r\n  \"seatNumbers\": [\"B5\"]\r\n}\r\n",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/bookings/book-seats",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"bookings",
								"book-seats"
							]
						}
					},
					"response": []
				}
			]
		},
