				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let responseData = pm.response.json();\r",
									"\r",
									"if (responseData.data && responseData.data.token) {\r",
									"    pm.environment.set(\"authToken\", responseData.data.token);\r",
									"} else {\r",
									"    console.log(\"No token found in response\");\r",
									"}\r",
									"\r",
									"pm.test(\"Status is 202 - Login successful\", function () {\r",
									"    pm.response.to.have.status(202);\r",
									"});\r",
									"\r",
									"pm.test(\"Login message confirmed\", function () {\r",
									"    const res = pm.response.json();\r",
									"    pm.expect(res.message).to.eql(\"Login successful\");\r",
									"});\r",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n  \"email\": \"{{email}}\",\r\n  \"password\": \"{{password}}\"\r\n}\r\n",
							"options": {
								"raw": {
